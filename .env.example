# ================================================================================
# Environment Configuration Template
# ================================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ================================================================================

# --------------------------------------------------------------------------------
# Application
# --------------------------------------------------------------------------------
APP_ENVIRONMENT=development
# Options: development, staging, production

# --------------------------------------------------------------------------------
# Database Connection
# --------------------------------------------------------------------------------
DB_SERVER=your-server.database.windows.net
DB_NAME=your_database
DB_USER=your_username
DB_PASSWORD=your_password
DB_PORT=1433
DB_DRIVER=ODBC Driver 18 for SQL Server

# --------------------------------------------------------------------------------
# API Configuration
# --------------------------------------------------------------------------------
API_BASE_URL=https://api.example.com
API_AUTH_TYPE=oauth2
API_CLIENT_ID=your_client_id
API_CLIENT_SECRET=your_client_secret
API_TOKEN_URL=https://auth.example.com/oauth2/token
API_SCOPES=read write

# --------------------------------------------------------------------------------
# Logging
# --------------------------------------------------------------------------------
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR
LOG_FILE=
# Optional: path to log file (e.g., logs/app.log)

# --------------------------------------------------------------------------------
# Feature Flags (optional)
# --------------------------------------------------------------------------------
# FEATURE_A_ENABLED=true
# FEATURE_B_ENABLED=false

# ================================================================================
# Server Configuration (Chi-Srv-01 — src/server/)
# ================================================================================
# These variables configure the FastAPI companion service on Chi-Srv-01.
# See docs/superpowers/specs/2026-04-15-server-crawl-walk-run-design.md §1.1

# --------------------------------------------------------------------------------
# Database (REQUIRED)
# --------------------------------------------------------------------------------
DATABASE_URL=mysql+aiomysql://obd2:your_password@localhost/obd2db
# Async MariaDB connection URL.  Format: mysql+aiomysql://user:pass@host/dbname

# --------------------------------------------------------------------------------
# Authentication
# --------------------------------------------------------------------------------
API_KEY=
# Shared-secret API key for X-API-Key header.  Leave empty to disable auth in dev.

# --------------------------------------------------------------------------------
# Server
# --------------------------------------------------------------------------------
PORT=8000
# HTTP port for uvicorn

# --------------------------------------------------------------------------------
# Logging
# --------------------------------------------------------------------------------
# LOG_LEVEL is already defined above in the general section.
# The server reads LOG_LEVEL from the environment (default: INFO).

# --------------------------------------------------------------------------------
# Ollama / AI (Chi-Srv-01 GPU)
# --------------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
# Base URL for the Ollama API.  Chi-Srv-01 runs Ollama locally on GPU.
# For Pi deployment, point at the remote Chi-Srv-01 instance instead:
# OLLAMA_BASE_URL=http://10.27.27.10:11434
# Resolved at runtime via the ${OLLAMA_BASE_URL:http://localhost:11434}
# placeholder in config.json (server.ai.ollamaBaseUrl).  See US-OLL-001.

OLLAMA_MODEL=llama3.1:8b
# Model to use for AI analysis.

# --------------------------------------------------------------------------------
# Backups
# --------------------------------------------------------------------------------
BACKUP_DIR=./data/backups
# Directory for received backup files from Pi uploads.

MAX_BACKUP_SIZE_MB=100
# Maximum allowed backup file size in megabytes.

BACKUP_RETENTION_COUNT=30
# Number of backup files to retain before rotation.

# --------------------------------------------------------------------------------
# Sync
# --------------------------------------------------------------------------------
MAX_SYNC_PAYLOAD_MB=10
# Maximum sync payload size in megabytes.

# --------------------------------------------------------------------------------
# Analysis
# --------------------------------------------------------------------------------
ANALYSIS_TIMEOUT_SECONDS=120
# Timeout for AI analysis requests in seconds.

TREND_WINDOW_DRIVES=10
# Number of recent drives used for trend analysis (rolling window).

ANOMALY_THRESHOLD_SIGMA=2.0
# Standard deviations threshold for anomaly flagging.

CALIBRATION_MIN_DRIVES=5
# Minimum real drives required before calibration recommendations are generated.

# ================================================================================
# Pi Companion Service (Chi-Srv-01 reach from Pi — src/pi/sync/)
# ================================================================================
# Used by the Pi-side SyncClient (US-149) to authenticate to Chi-Srv-01's
# /api/v1/sync endpoint.  Must match the server-side API_KEY above when both
# tiers run in the same deployment.

COMPANION_API_KEY=your-api-key-here
# Shared-secret key sent in the X-API-Key header on every sync request.
